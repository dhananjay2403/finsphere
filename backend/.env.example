# Server
PORT=5001
NODE_ENV=development

# MongoDB:

# Option 1: Local MongoDB (default for development)
MONGO_URI=mongodb://localhost:27017/finsphere

# Option 2: MongoDB Atlas (uncomment and replace with your Atlas URI)
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/finsphere?retryWrites=true&w=majority

# JWT 
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key_here

# CORS — comma-separated list of allowed origins (e.g. your deployed frontend URL).
# Leave unset in development to allow all origins.
# CORS_ORIGIN=https://finsphere.vercel.app

# Redis (optional)
# Caches public market data (quotes, candles, news) to reduce Finnhub API usage. Leave unset to run without a cache; the app degrades gracefully and behaves exactly as it does today.
# Local:      REDIS_URL=redis://localhost:6379
# Hosted:     REDIS_URL=rediss://<user>:<password>@<host>:<port> (Render Key Value, Upstash, Redis Cloud, etc.)
# REDIS_URL=redis://localhost:6379
